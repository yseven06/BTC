# ============================================
# TradeMinds AI - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
#
# PRODUCTION (Railway): do NOT ship a .env file. Set every value below as a
# Railway service variable. For production also set:
#   DEBUG=false   ENVIRONMENT=production
#   GOOGLE_REDIRECT_URI=https://<api-domain>/api/v1/auth/google/callback
#   FRONTEND_BASE_URL=https://<frontend-domain>
#   CORS_ORIGINS=["https://<frontend-domain>"]
# See docs/DEPLOYMENT.md for the full deploy guide.

# --- Application ---
APP_NAME=TradeMinds AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
API_PREFIX=/api/v1

# --- Supabase PostgreSQL ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# --- Upstash Redis ---
UPSTASH_REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# --- JWT Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Binance API ---
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_BASE_URL=https://api.binance.com

# --- CoinGecko API ---
COINGECKO_API_KEY=your-coingecko-api-key
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# --- FRED (macro) API ---
FRED_API_KEY=your-fred-api-key

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# --- Frontend base (used for OAuth / Stripe redirects) ---
FRONTEND_BASE_URL=http://localhost:3000

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Logging ---
LOG_LEVEL=INFO

# --- Monitoring (Sentry) — leave DSN empty to disable ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
