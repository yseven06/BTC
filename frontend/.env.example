# ============================================
# TradeMinds AI - Frontend Environment (Next.js)
# ============================================
# Copy to .env.local for local dev. NEXT_PUBLIC_* values are exposed to the
# browser — put NO secrets here.
#
# PRODUCTION (Vercel): set these as Vercel project Environment Variables.

# Backend API base (Railway backend URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (used for SEO metadataBase / OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry (error monitoring) — leave empty to disable. Use the EU/US DSN that
# matches your Sentry project region.
NEXT_PUBLIC_SENTRY_DSN=

# PostHog product analytics — leave key empty to disable. EU Cloud by default;
# capture is also consent-gated (cookie banner) so nothing is sent until the
# user opts in. APP_VERSION is attached to every event.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_APP_VERSION=1.0.0

# Cloudflare Turnstile (adaptive bot challenge) — PUBLIC site key (safe to expose).
# Empty = widget never renders (no-op). Pair with backend TURNSTILE_SECRET_KEY.
# Dev/CI always-pass test key: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=


